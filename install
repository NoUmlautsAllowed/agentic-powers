#!/bin/bash
set -euo pipefail

# 1. Argument Parsing
PROVIDER=${1:-}
if [[ -z "$PROVIDER" ]] || [[ "$PROVIDER" != "junie" && "$PROVIDER" != "opencode" && "$PROVIDER" != "claude" ]]; then
    echo "Usage: ./install [junie|opencode|claude]"
    exit 1
fi

# 2. Environment Sourcing
if [ -f .env.defaults ]; then
    set -a
    source .env.defaults
    set +a
fi

if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# Apply provider-specific overrides
if [ -z "${MODEL:-}" ]; then
    if [ "$PROVIDER" == "opencode" ]; then
        export MODEL="ollama/gemma4:26b"
    elif [ "$PROVIDER" == "junie" ]; then
        export MODEL="inherit"
    fi
fi

# 3. Rendering Settings
# Determine which CUSTOM block to use
PROVIDER_UPPER=$(printf '%s' "$PROVIDER" | tr '[:lower:]' '[:upper:]') 
CUSTOM_VAR="${PROVIDER_UPPER}_CUSTOM"
CUSTOM_VAL="${!CUSTOM_VAR:-}"

# 4. Directory Management
TARGET_DIR="$HOME/.$PROVIDER"
if [[ "$PROVIDER" == "opencode" ]]; then
    TARGET_DIR="$HOME/.config/opencode"
fi

# Setup install directories
INSTALL_DIR=".install/$PROVIDER"
mkdir -p "$INSTALL_DIR/agents" "$INSTALL_DIR/skills"

# Copy all files to INSTALL_DIR
cp -r agents/. "$INSTALL_DIR/agents/"
cp -r skills/. "$INSTALL_DIR/skills/"

echo "Applying multi-stage rendering inline..."

# Perform template variable replacement inline on .md files
find "$INSTALL_DIR/agents" "$INSTALL_DIR/skills" -type f -name "*.md" | while read -r file; do
    # Pipeline:
    # 1. Base replacements (MODEL, MODE)
    # 2. CUSTOM injection
    # 3. Variable expansion within the result (Second Rendering)
    if sed --version >/dev/null 2>&1; then
      # GNU sed
      sed -i \
        -e "s|{{MODEL}}|$MODEL|g" \
        -e "s|{{MODE}}|$MODE|g" \
        -e "s|{{CUSTOM}}|$CUSTOM_VAL|g" \
        "$file"
    else
      # BSD (macOS) sed
      sed -i '' \
        -e "s|{{MODEL}}|$MODEL|g" \
        -e "s|{{MODE}}|$MODE|g" \
        -e "s|{{CUSTOM}}|$CUSTOM_VAL|g" \
        "$file"
    fi
done

# 5. Symlinking
mkdir -p "$(dirname "$TARGET_DIR")"

# Only delete $TARGET_DIR/skills if it is a symlink
if [ -L "$TARGET_DIR/skills" ]; then
    rm "$TARGET_DIR/skills"
elif [ -d "$TARGET_DIR/skills" ] && [ -z "$(ls -A "$TARGET_DIR/skills")" ]; then
    rmdir "$TARGET_DIR/skills"
fi

if [ -L "$TARGET_DIR/agents" ]; then
    rm "$TARGET_DIR/agents"
elif [ -d "$TARGET_DIR/agents" ] && [ -z "$(ls -A "$TARGET_DIR/agents")" ]; then
    rmdir "$TARGET_DIR/agents"
fi

ABS_INSTALL_DIR="$(pwd)/$INSTALL_DIR"
ln -svf "$ABS_INSTALL_DIR/skills" "$TARGET_DIR/skills"
ln -svf "$ABS_INSTALL_DIR/agents" "$TARGET_DIR/agents"

echo "Successfully installed $PROVIDER to $TARGET_DIR"
echo "Configuration applied to $ABS_INSTALL_DIR"
